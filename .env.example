# Mantle local development environment
# Copy to .env and adjust values: cp .env.example .env

# Admin API bearer token (required for /admin/* routes)
MANTLE_ADMIN_TOKEN=change-me-in-production

# MinIO / S3-compatible storage (local docker-compose)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://minio:9000

# Prebuilt deploy (EC2 / production — pull from GHCR instead of building on host)
# GHCR_IMAGE_PREFIX=ghcr.io/YOUR_GITHUB_USER
# MANTLE_IMAGE_TAG=latest

# Optional overrides
# MANTLE_CONFIG=/config.toml
# RAY_ADDRESS=ray://ray-head:10001
